        color: var(--text-subtle);
    }

    .april-fool-notice {
        margin-bottom: 22px;
        padding: 18px;
        border-radius: 22px;
        background: linear-gradient(180deg, rgba(255, 251, 235, 0.96), rgba(255, 247, 237, 0.88));
        border: 1px solid rgba(245, 158, 11, 0.2);
        color: #92400e;
        font-size: 0.92rem;
        line-height: 1.8;
    }

    .april-fool-notice p {
        margin: 0 0 8px;
    }

    .notice-title {
        font-weight: 800;
        color: #b45309;
    }

    .notice-warn {
        margin-bottom: 0;
        color: #b91c1c;
        font-weight: 700;
    }

    .spinner {
        width: 34px;
        height: 34px;
        border: 3px solid rgba(11, 106, 103, 0.14);
        border-top: 3px solid var(--primary);
        border-radius: 999px;
        animation: spin 0.9s linear infinite;
    }

    #loading-overlay {
        position: absolute;
        inset: 0;
        z-index: 5;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 34px;
        background: rgba(248, 250, 252, 0.55);
        backdrop-filter: blur(10px);
    }

    .modal-overlay {
        position: fixed;
        inset: 0;
        z-index: 2000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 24px;
        background: rgba(15, 23, 42, 0.36);
        backdrop-filter: blur(10px);
    }

    .captcha-popup {
        width: min(440px, 100%);
        max-height: min(760px, calc(100dvh - 28px));
        overflow: hidden;
        border-radius: 28px;
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(148, 163, 184, 0.2);
        box-shadow: 0 30px 80px rgba(15, 23, 42, 0.24);
        display: flex;
        flex-direction: column;
    }

    .captcha-title {
        padding: 18px 22px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 800;
        font-size: 0.95rem;
        color: var(--text);
        border-bottom: 1px solid rgba(148, 163, 184, 0.16);
    }

    .close-x {
        width: 36px;
        height: 36px;
        border: 0;
        border-radius: 999px;
        background: rgba(248, 250, 252, 0.94);
        color: #64748b;
        font-size: 1.5rem;
        cursor: pointer;
    }

    .captcha-body {
        overflow: auto;
    }

    .captcha-header {
        padding: 22px;
        display: flex;
        flex-direction: column;
        align-items: center;
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.95), rgba(255, 255, 255, 0.9));
        border-bottom: 1px solid rgba(148, 163, 184, 0.15);
    }

    .captcha-image-box {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        width: 100%;
        justify-content: center;
    }

    #captcha-img {
        height: 52px;
        border-radius: 14px;
        border: 1px solid rgba(148, 163, 184, 0.18);
        background: #fff;
    }

    .refresh-btn {
        width: 38px;
        height: 38px;
        border-radius: 999px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: rgba(255, 255, 255, 0.94);
        color: #475569;
        cursor: pointer;
        font-size: 0.95rem;
        font-weight: 700;
        box-shadow: 0 6px 16px rgba(15, 23, 42, 0.06);
        transition: transform 0.16s ease, border-color 0.16s ease, color 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
    }

    .refresh-btn:hover {
        color: var(--primary-strong);
        border-color: rgba(11, 106, 103, 0.34);
        background: rgba(236, 254, 255, 0.98);
        box-shadow: 0 10px 20px rgba(11, 106, 103, 0.12);
        transform: translateY(-1px);
    }

    .captcha-guide {
        font-size: 0.82rem;
        line-height: 1.7;
        color: var(--text-subtle);
        text-align: center;
    }

    .captcha-main-area {
        display: flex;
        gap: 16px;
        padding: 18px;
        background: rgba(255, 255, 255, 0.95);
    }

    .captcha-grid {
        flex: 1;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        grid-template-rows: repeat(5, 1fr);
        gap: 8px;
        padding: 6px;
        border-radius: 16px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.74), rgba(248, 250, 252, 0.9));
    }

    :global(.captcha-btn) {
        min-height: 40px;
        border-radius: 11px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.94));
        font-size: 0.8rem;
        color: #334155;
        cursor: pointer;
        font-weight: 700;
        letter-spacing: 0.01em;
        font-family: 'SFMono-Regular', Menlo, monospace;
        box-shadow: 0 5px 12px rgba(15, 23, 42, 0.05);
        transition: transform 0.16s ease, border-color 0.16s ease, color 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
    }

    :global(.captcha-btn:hover) {
        border-color: rgba(11, 106, 103, 0.3);
        color: var(--primary-strong);
        background: linear-gradient(180deg, rgba(255, 255, 255, 1), rgba(241, 245, 249, 0.96));
        box-shadow: 0 10px 20px rgba(15, 23, 42, 0.09);
        transform: translateY(-1px);
    }

    :global(.captcha-btn:focus-visible) {
        outline: none;
        border-color: rgba(11, 106, 103, 0.44);
        box-shadow: 0 0 0 3px rgba(11, 106, 103, 0.14), 0 6px 14px rgba(15, 23, 42, 0.08);
    }

    :global(.captcha-btn:active) {
        transform: translateY(0);
        background: linear-gradient(180deg, rgba(248, 250, 252, 0.98), rgba(241, 245, 249, 0.98));
        box-shadow: 0 3px 10px rgba(15, 23, 42, 0.08);
    }

    .captcha-slider-box {
        width: 30px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
    }

    .slider-adjust-btn {
        width: 28px;
        height: 28px;
        border-radius: 8px;
        border: 1px solid rgba(148, 163, 184, 0.24);
        background: rgba(255, 255, 255, 0.94);
        font-size: 10px;
        color: #475569;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 5px 12px rgba(15, 23, 42, 0.05);
        transition: transform 0.16s ease, border-color 0.16s ease, color 0.16s ease, box-shadow 0.16s ease, background 0.16s ease;
    }

    .slider-adjust-btn:hover {
        color: var(--primary-strong);
        border-color: rgba(11, 106, 103, 0.34);
        background: rgba(236, 254, 255, 0.98);
        box-shadow: 0 10px 18px rgba(11, 106, 103, 0.1);
        transform: translateY(-1px);
    }

    #captcha-nav-slider {
        -webkit-appearance: none;
        width: 6px;
        flex: 1;
        border-radius: 999px;
        outline: none;
        background: rgba(203, 213, 225, 0.74);
        writing-mode: bt-lr;
        appearance: slider-vertical;
        transform: rotate(180deg);
    }

    #captcha-nav-slider::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 18px;
        height: 18px;
        border-radius: 999px;
        background: #fff;
        border: 2px solid var(--primary);
        cursor: pointer;
        box-shadow: 0 8px 16px rgba(11, 106, 103, 0.16);
    }

    .captcha-footer {
        padding: 14px 18px 18px;
        border-top: 1px solid rgba(148, 163, 184, 0.16);
        background: rgba(248, 250, 252, 0.9);
    }

    .captcha-footer .cancel-btn {
        height: 44px;
        border-radius: 12px;
        border-color: rgba(148, 163, 184, 0.24);
        background: rgba(255, 255, 255, 0.94);
        color: #334155;
        font-size: 0.9rem;
        font-weight: 700;
        box-shadow: 0 6px 14px rgba(15, 23, 42, 0.05);
    }

    .captcha-footer .cancel-btn:hover {
        border-color: rgba(11, 106, 103, 0.34);
        color: var(--primary-strong);
        background: rgba(236, 254, 255, 0.98);
        box-shadow: 0 12px 22px rgba(11, 106, 103, 0.12);
    }

    @keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }

    @keyframes shell-enter {
        from {
            opacity: 0;
            transform: translateY(6px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @keyframes shield-float {
        0%, 100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-3px);
        }
    }

