<div class="login-shell">
    <section class="login-container">
        <div class="brand-panel">
            <div class="brand-orb brand-orb-a"></div>
            <div class="brand-orb brand-orb-b"></div>
            <div class="brand-grid"></div>
            <div class="brand-stack">
                <div class="stack-card stack-card-a"></div>
                <div class="stack-card stack-card-b"></div>
                <div class="stack-card stack-card-c"></div>
            </div>
        </div>

        <div class="login-card">
            <div class="card-glow"></div>
            <div class="card-confetti card-confetti-a"></div>
            <div class="card-confetti card-confetti-b"></div>
            <div class="card-confetti card-confetti-c"></div>
            <div id="auth-view">
                <div class="login-header">
                    <h2 id="form-title">账号登录</h2>
                    <p id="form-subtitle">管理您的个人身份及访问权限</p>
                </div>

                <form id="uip-form">
                    <div class="form-item">
                        <label for="username">用户名</label>
                        <input type="text" id="username" name="username" placeholder="请输入您的用户名" />
                    </div>

                    <div class="form-item hidden" id="email-field">
                        <label for="email">邮箱地址</label>
                        <div class="input-with-action">
                            <input type="email" id="email" name="email" placeholder="请输入电子邮箱" />
                            <button type="button" id="send-code-btn" class="inline-button">发送验证码</button>
                        </div>
                    </div>

                    <div class="form-item hidden" id="code-field">
                        <label for="code">PoW 验证码</label>
                        <input type="text" id="code" name="code" placeholder="请输入证明字符串" />
                    </div>

                    <div class="form-item hidden" id="age-field">
                        <label for="age">年龄</label>
                        <div class="stepper-input">
                            <button type="button" class="step-btn" id="age-minus">-</button>
                            <input type="number" id="age" name="age" step="1" value="" placeholder="请选择年龄" readonly />
                            <button type="button" class="step-btn" id="age-plus">+</button>
                        </div>
                    </div>

                    <div class="form-item">
                        <label for="password">密码</label>
                        <input type="password" id="password" name="password" placeholder="请输入您的密码" />
                    </div>

                    <div class="form-item hidden" id="confirm-password-field">
                        <label for="confirm-password">确认密码</label>
                        <input type="password" id="confirm-password" name="confirm-password" placeholder="请再次输入您的密码" />
                    </div>

                    <button type="submit" id="submit-btn" class="primary-button">确认提交</button>

                    <div class="form-toggle">
                        <a href="#" id="toggle-link">没有账号？点击注册</a>
                    </div>
                </form>
            </div>

            <div id="2fa-view" class="hidden">
                <div class="login-header">
                    <h2 id="2fa-title">两步验证</h2>
                    <p id="2fa-msg">为了安全，请使用生物识别或硬件密钥</p>
                </div>
                <div class="twofa-icon-box" aria-hidden="true">
                    <span class="shield-core"></span>
                    <span class="shield-check"></span>
                </div>
                <button id="webauthn-btn" class="primary-button">立即验证</button>
                <div class="form-toggle">
                    <a href="#" id="back-to-login">返回常规登录</a>
                </div>
            </div>

            <div id="dashboard-view" class="hidden">
                <div class="dash-header">
                    <div class="user-avatar">U</div>
                    <div class="user-info">
                        <h3 id="dash-username">...</h3>
                        <p>在线</p>
                    </div>
                </div>

                <div class="april-fool-notice">
                    <p class="notice-title">祝你愚人节快乐！</p>
                    <p>这是一个愚人节项目，意在通过刻意设计给用户带来不好的使用体验。</p>
                    <p>项目源码：<a href="https://github.com/nhirsama/foolsignup" target="_blank">https://github.com/nhirsama/foolsignup</a></p>
                    <p class="notice-warn">提醒：如果您在注册时使用了常用密码，建议立即修改其他网站的相同密码以确保安全。</p>
                </div>

                <button class="secondary-button" id="logout-btn">安全退出系统</button>
            </div>

            <div id="alert-container" class="alert-container">
                <div id="error-alert" class="alert error hidden">
                    <span id="error-text"></span>
                </div>
                <div id="success-alert" class="alert success hidden"></div>
            </div>

            <div id="loading-overlay" class="hidden"><div class="spinner"></div></div>
        </div>
    </section>
</div>

<div id="captcha-modal" class="modal-overlay hidden">
    <div class="captcha-popup">
        <div class="captcha-title">
            <span>安全验证</span>
            <button id="close-captcha-x" class="close-x">&times;</button>
        </div>
        <div class="captcha-body">
            <div class="captcha-header">
                <div class="captcha-image-box">
                    <img id="captcha-img" src="" alt="CAPTCHA" />
                    <button id="refresh-captcha" class="refresh-btn" title="刷新验证码">⟳</button>
                </div>
                <div class="captcha-guide">请通过滑块定位并点击与图片一致的数字：</div>
            </div>
            <div class="captcha-main-area">
                <div id="captcha-grid" class="captcha-grid"></div>
                <div class="captcha-slider-box">
                    <button type="button" class="slider-adjust-btn" id="slider-up">▲</button>
                    <input type="range" id="captcha-nav-slider" min="0" max="249995" value="0" step="1" />
                    <button type="button" class="slider-adjust-btn" id="slider-down">▼</button>
                </div>
            </div>
        </div>
        <div class="captcha-footer">
            <button type="button" id="close-captcha-btn" class="cancel-btn">取消</button>
        </div>
    </div>
</div>

<style>
    :root {
        --primary: #0b6a67;
        --primary-strong: #0a4f4d;
        --accent: #f59e0b;
        --surface: rgba(255, 255, 255, 0.76);
        --surface-strong: rgba(255, 255, 255, 0.9);
        --surface-border: rgba(15, 23, 42, 0.11);
        --text: #0f172a;
        --text-subtle: #5b6475;
        --error: #b91c1c;
        --success: #166534;
        --shadow-xl: 0 28px 90px rgba(15, 23, 42, 0.16);
    }

    .login-shell {
        width: 100%;
        animation: shell-enter 520ms ease both;
    }

    .login-container {
        width: min(1180px, 100%);
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(360px, 460px);
        gap: clamp(20px, 3.2vw, 36px);
        align-items: stretch;
        position: relative;
        z-index: 1;
    }

    .brand-panel,
    .login-card {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--surface-border);
        box-shadow: var(--shadow-xl);
        backdrop-filter: blur(18px);
    }

    .brand-panel {
        min-height: 700px;
        border-radius: 34px;
        background:
            radial-gradient(circle at 16% 20%, rgba(11, 106, 103, 0.26), transparent 30%),
            radial-gradient(circle at 84% 78%, rgba(245, 158, 11, 0.2), transparent 28%),
            linear-gradient(148deg, rgba(255, 255, 255, 0.82), rgba(236, 254, 255, 0.34));
    }

    .brand-panel::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            linear-gradient(rgba(15, 23, 42, 0.06) 1px, transparent 1px),
            linear-gradient(90deg, rgba(15, 23, 42, 0.06) 1px, transparent 1px);
        background-size: 30px 30px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.8), transparent 85%);
        opacity: 0.44;
    }

    .brand-orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(6px);
        pointer-events: none;
    }

    .brand-orb-a {
        width: 240px;
        height: 240px;
        top: 64px;
        left: 52px;
        background: radial-gradient(circle, rgba(11, 106, 103, 0.26), rgba(11, 106, 103, 0.04) 70%, transparent 74%);
    }

    .brand-orb-b {
        width: 300px;
        height: 300px;
        right: 40px;
        bottom: 44px;
        background: radial-gradient(circle, rgba(245, 158, 11, 0.2), rgba(245, 158, 11, 0.05) 64%, transparent 72%);
    }

    .brand-grid {
        position: absolute;
        inset: 0;
    }

    .brand-stack {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .stack-card {
        position: absolute;
        width: min(82%, 430px);
        aspect-ratio: 1.06;
        border-radius: 34px;
        border: 1px solid rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(9px);
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.13);
    }

    .stack-card-a {
        transform: rotate(-13deg) translate(-34px, 12px);
        background: linear-gradient(160deg, rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.16));
    }

    .stack-card-b {
        transform: rotate(10deg) translate(42px, -16px);
        background: linear-gradient(160deg, rgba(236, 254, 255, 0.8), rgba(255, 255, 255, 0.2));
    }

    .stack-card-c {
        transform: rotate(-1.6deg);
        background:
            linear-gradient(138deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.42)),
            radial-gradient(circle at top right, rgba(11, 106, 103, 0.16), transparent 34%);
    }

    .stack-card-c::before,
    .stack-card-c::after,
    .stack-card-a::before,
    .stack-card-a::after {
        content: '';
        position: absolute;
        border-radius: 999px;
    }

    .stack-card-c::before {
        left: 32px;
        top: 36px;
        width: 36%;
        height: 14px;
        background: rgba(15, 23, 42, 0.12);
    }

    .stack-card-c::after {
        left: 32px;
        top: 62px;
        width: 52%;
        height: 9px;
        background: rgba(15, 23, 42, 0.08);
    }

    .stack-card-a::before {
        inset: 28px 28px auto;
        height: 98px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.32);
    }

    .stack-card-a::after {
        inset: auto 28px 28px;
        height: 64px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.36);
    }

    .login-card {
        background: linear-gradient(180deg, var(--surface-strong), var(--surface));
        border-radius: 34px;
        min-height: 700px;
        padding: clamp(24px, 3vw, 34px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        isolation: isolate;
    }

    .card-glow {
        position: absolute;
        inset: -38% auto auto 54%;
        width: 250px;
        height: 250px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(11, 106, 103, 0.2), transparent 72%);
        pointer-events: none;
    }

    .card-confetti {
        position: absolute;
        z-index: 0;
        pointer-events: none;
    }

    .card-confetti-a {
        top: 36px;
        right: 38px;
        width: 13px;
        height: 13px;
        border-radius: 4px;
        transform: rotate(17deg);
        background: rgba(245, 158, 11, 0.34);
    }

    .card-confetti-b {
        top: 90px;
        right: 64px;
        width: 24px;
        height: 6px;
        border-radius: 999px;
        transform: rotate(-20deg);
        background: rgba(11, 106, 103, 0.22);
    }

    .card-confetti-c {
        left: 26px;
        bottom: 112px;
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: rgba(236, 72, 153, 0.2);
    }

    #auth-view,
    #2fa-view,
    #dashboard-view {
        position: relative;
        z-index: 1;
    }

    .login-header {
        margin-bottom: 28px;
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        align-self: flex-start;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.66);
        border: 1px solid rgba(15, 23, 42, 0.1);
        color: var(--primary-strong);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 11px;
        font-weight: 700;
    }

    .login-header h2 {
        margin: 14px 0 8px;
        font-size: clamp(2rem, 4vw, 2.75rem);
        line-height: 1;
        letter-spacing: -0.05em;
        color: var(--text);
    }

    .login-header h2::after {
        content: '';
        display: block;
        width: 58px;
        height: 6px;
        margin-top: 14px;
        border-radius: 999px;
        transform: rotate(-2deg);
        transform-origin: left center;
        background: linear-gradient(90deg, rgba(11, 106, 103, 0.84), rgba(245, 158, 11, 0.5));
    }

    .login-header p {
        margin: 0;
        color: var(--text-subtle);
        font-size: 0.97rem;
        line-height: 1.7;
    }

    .form-item {
        margin-bottom: 16px;
    }

    .form-item label {
        display: block;
        margin-bottom: 8px;
        font-size: 0.85rem;
        font-weight: 700;
        color: #334155;
        letter-spacing: 0.01em;
    }

    input {
        width: 100%;
        height: 52px;
        padding: 0 16px;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.28);
        background: rgba(255, 255, 255, 0.88);
        color: var(--text);
        font-size: 0.96rem;
        box-sizing: border-box;
        transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease, background 0.18s ease;
    }

    input::placeholder {
        color: #94a3b8;
    }

    input:focus {
        outline: none;
        border-color: rgba(11, 106, 103, 0.6);
        box-shadow: 0 0 0 4px rgba(11, 106, 103, 0.11);
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.98);
    }

    input[readonly] {
        background: rgba(248, 250, 252, 0.94);
        color: #475569;
        cursor: default;
    }

    .input-with-action {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 112px;
        gap: 10px;
        align-items: center;
    }

    .input-with-action input {
        min-width: 0;
    }

    .input-with-action .inline-button {
        width: 112px;
        min-width: 112px;
    }

    .stepper-input {
        display: grid;
        grid-template-columns: 52px minmax(0, 1fr) 52px;
        align-items: center;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.28);
        background: rgba(255, 255, 255, 0.88);
        overflow: hidden;
    }

    .stepper-input input {
        border: 0;
        border-left: 1px solid rgba(148, 163, 184, 0.2);
        border-right: 1px solid rgba(148, 163, 184, 0.2);
        border-radius: 0;
        text-align: center;
        background: transparent;
    }

    .stepper-input input:focus {
        box-shadow: none;
        transform: none;
    }

    .step-btn,
    .inline-button,
    .secondary-button,
    .cancel-btn,
    .slider-adjust-btn {
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease, color 0.18s ease, box-shadow 0.18s ease;
    }

    .step-btn {
        height: 52px;
        border: 0;
        background: transparent;
        color: #64748b;
        font-size: 1.28rem;
        cursor: pointer;
    }

    .step-btn:hover,
    .slider-adjust-btn:hover {
        color: var(--primary);
        background: rgba(11, 106, 103, 0.09);
    }

    .inline-button {
        flex-shrink: 0;
        min-width: 112px;
        height: 52px;
        padding: 0 16px;
        border-radius: 18px;
        border: 1px solid rgba(11, 106, 103, 0.2);
        background: rgba(236, 254, 255, 0.92);
        color: var(--primary-strong);
        font-size: 0.88rem;
        font-weight: 700;
        cursor: pointer;
    }

    .inline-button:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 12px 28px rgba(11, 106, 103, 0.12);
    }

    .inline-button:disabled {
        color: #94a3b8;
        background: rgba(248, 250, 252, 0.9);
        border-color: rgba(148, 163, 184, 0.18);
        cursor: not-allowed;
    }

    .primary-button {
        width: 100%;
        height: 56px;
        margin-top: 8px;
        border: 0;
        border-radius: 18px;
        background:
            linear-gradient(135deg, rgba(255, 255, 255, 0.1), transparent 34%),
            linear-gradient(135deg, var(--primary), var(--primary-strong));
        color: #f8fafc;
        font-size: 0.96rem;
        font-weight: 700;
        letter-spacing: 0.01em;
        cursor: pointer;
        box-shadow: 0 16px 34px rgba(11, 106, 103, 0.24);
    }

    .primary-button:hover {
        transform: translateY(-1px);
        box-shadow: 0 20px 44px rgba(11, 106, 103, 0.32);
    }

    .secondary-button,
    .cancel-btn {
        width: 100%;
        height: 52px;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.22);
        background: rgba(255, 255, 255, 0.74);
        color: #334155;
        cursor: pointer;
        font-size: 0.94rem;
        font-weight: 700;
    }

    .secondary-button:hover,
    .cancel-btn:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.92);
    }

    .form-toggle {
        margin-top: 18px;
        text-align: center;
    }

    .form-toggle a,
    .april-fool-notice a {
        color: var(--primary-strong);
        text-decoration: none;
        font-weight: 700;
    }

    .form-toggle a:hover,
    .april-fool-notice a:hover {
        text-decoration: underline;
    }

    .alert-container {
        min-height: 62px;
        margin-top: 18px;
    }

    .alert {
        width: 100%;
        padding: 14px 16px;
        border-radius: 18px;
        font-size: 0.9rem;
        line-height: 1.6;
        text-align: center;
        border: 1px solid transparent;
        box-sizing: border-box;
        backdrop-filter: blur(10px);
    }

    .alert.error {
        background: rgba(254, 226, 226, 0.82);
        color: var(--error);
        border-color: rgba(239, 68, 68, 0.16);
    }

    .alert.success {
        background: rgba(220, 252, 231, 0.82);
        color: var(--success);
        border-color: rgba(34, 197, 94, 0.16);
    }

    .hidden {
        display: none !important;
    }

    #2fa-view {
        padding: clamp(18px, 2.2vw, 24px);
        border-radius: 26px;
        border: 1px solid rgba(11, 106, 103, 0.16);
        background:
            radial-gradient(circle at 86% 12%, rgba(245, 158, 11, 0.17), transparent 34%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(236, 254, 255, 0.6));
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.62), 0 18px 34px rgba(15, 23, 42, 0.08);
    }

    #2fa-view .login-header {
        text-align: center;
        margin-bottom: 22px;
    }

    #2fa-view .login-header h2 {
        margin-top: 0;
        font-size: clamp(1.8rem, 3vw, 2.2rem);
    }

    #2fa-view .login-header h2::after {
        width: 48px;
        margin-left: auto;
        margin-right: auto;
        transform: none;
    }

    #2fa-view .login-header p {
        max-width: 30ch;
        margin: 0 auto;
    }

    #2fa-view .primary-button {
        margin-top: 2px;
    }

    #2fa-view .form-toggle {
        margin-top: 14px;
    }

    .twofa-icon-box {
        position: relative;
        width: 144px;
        height: 144px;
        margin: 6px auto 20px;
        border-radius: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
            radial-gradient(circle at 14% 16%, rgba(11, 106, 103, 0.2), transparent 48%),
            radial-gradient(circle at 86% 14%, rgba(245, 158, 11, 0.18), transparent 44%),
            linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(236, 254, 255, 0.72));
        border: 1px solid rgba(11, 106, 103, 0.16);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.78),
            0 14px 30px rgba(11, 106, 103, 0.14);
        animation: shield-float 2.6s ease-in-out infinite;
    }

    .twofa-icon-box::before {
        content: '';
        position: absolute;
        inset: 11px;
        border-radius: 24px;
        border: 1px solid rgba(11, 106, 103, 0.18);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0.1));
        pointer-events: none;
    }

    .twofa-icon-box::after {
        content: '';
        position: absolute;
        left: 50%;
        top: 20px;
        width: 56px;
        height: 10px;
        transform: translateX(-50%);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.6);
        filter: blur(0.5px);
        pointer-events: none;
    }

    .shield-core {
        position: relative;
        z-index: 1;
        width: 58px;
        height: 68px;
        background: linear-gradient(180deg, rgba(11, 106, 103, 0.95), rgba(10, 79, 77, 0.92));
        clip-path: polygon(50% 0, 88% 14%, 88% 48%, 50% 100%, 12% 48%, 12% 14%);
        box-shadow: 0 10px 20px rgba(10, 79, 77, 0.34);
    }

    .shield-core::before {
        content: '';
        position: absolute;
        inset: 6px 8px 10px;
        clip-path: polygon(50% 0, 88% 14%, 88% 48%, 50% 100%, 12% 48%, 12% 14%);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.06));
    }

    .shield-check {
        position: absolute;
        z-index: 2;
        width: 18px;
        height: 10px;
        border-left: 3px solid #ecfeff;
        border-bottom: 3px solid #ecfeff;
        transform: translate(2px, 8px) rotate(-45deg);
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.2);
    }

    .shield-check::after {
        content: '';
        position: absolute;
        right: -20px;
        top: -22px;
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: rgba(245, 158, 11, 0.5);
        box-shadow: 0 0 0 8px rgba(245, 158, 11, 0.12);
    }

    .dash-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        padding-bottom: 18px;
