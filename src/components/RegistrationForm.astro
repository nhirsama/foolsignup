<div class="login-container">
    <div class="login-card">
        <div id="auth-view">
            <div class="login-header">
                <h2 id="form-title">账号登录</h2>
                <p id="form-subtitle">管理您的个人身份及访问权限</p>
            </div>

            <form id="uip-form">
                <div class="form-item">
                    <label for="username">用户名</label>
                    <input type="text" id="username" name="username" placeholder="请输入您的用户名" />
                </div>

                <div class="form-item hidden" id="email-field">
                    <label for="email">邮箱地址</label>
                    <div class="input-with-action">
                        <input type="email" id="email" name="email" placeholder="请输入电子邮箱" />
                        <button type="button" id="send-code-btn" class="inline-button">发送验证码</button>
                    </div>
                </div>

                <div class="form-item hidden" id="code-field">
                    <label for="code">PoW 验证码</label>
                    <input type="text" id="code" name="code" placeholder="请输入证明字符串" />
                </div>

                <div class="form-item hidden" id="age-field">
                    <label for="age">年龄</label>
                    <div class="stepper-input">
                        <button type="button" class="step-btn" id="age-minus">-</button>
                        <input type="number" id="age" name="age" step="1" value="" placeholder="请选择年龄" readonly />
                        <button type="button" class="step-btn" id="age-plus">+</button>
                    </div>
                </div>

                <div class="form-item">
                    <label for="password">密码</label>
                    <input type="password" id="password" name="password" placeholder="请输入您的密码" />
                </div>

                <div class="form-item hidden" id="confirm-password-field">
                    <label for="confirm-password">确认密码</label>
                    <input type="password" id="confirm-password" name="confirm-password" placeholder="请再次输入您的密码" />
                </div>

                <button type="submit" id="submit-btn" class="primary-button">确认提交</button>
                
                <div class="form-toggle">
                    <a href="#" id="toggle-link">没有账号？点击注册</a>
                </div>
            </form>
        </div>

        <!-- 2FA 验证视图 -->
        <div id="2fa-view" class="hidden">
            <div class="login-header">
                <h2 id="2fa-title">两步验证</h2>
                <p id="2fa-msg">为了安全，请使用生物识别或硬件密钥</p>
            </div>
            <div class="twofa-icon-box" style="font-size: 64px; text-align: center; margin: 20px 0;">🛡️</div>
            <button id="webauthn-btn" class="primary-button">立即验证</button>
            <div class="form-toggle">
                <a href="#" id="back-to-login">返回常规登录</a>
            </div>
        </div>

        <!-- 登录成功后的 Dashboard -->
        <div id="dashboard-view" class="hidden">
            <div class="dash-header">
                <div class="user-avatar">U</div>
                <div class="user-info">
                    <h3 id="dash-username">...</h3>
                    <p>在线 · 企业认证实体</p>
                </div>
            </div>
            <button class="secondary-button" id="logout-btn">安全退出系统</button>
        </div>

        <!-- 错误提示容器 -->
        <div id="alert-container" class="alert-container" style="margin-top: 20px;">
            <div id="error-alert" class="alert error hidden">
                <span id="error-text"></span>
            </div>
            <div id="success-alert" class="alert success hidden"></div>
        </div>

        <div id="loading-overlay" class="hidden"><div class="spinner"></div></div>
    </div>
</div>

<div id="captcha-modal" class="modal-overlay hidden">
    <div class="captcha-popup">
        <div class="captcha-title">
            <span>安全验证</span>
            <button id="close-captcha-x" class="close-x">&times;</button>
        </div>
        <div class="captcha-body">
            <div class="captcha-header">
                <div class="captcha-image-box">
                    <img id="captcha-img" src="" alt="CAPTCHA" />
                    <button id="refresh-captcha" class="refresh-btn" title="刷新验证码">⟳</button>
                </div>
                <div class="captcha-guide">请通过滑块定位并点击与图片一致的数字：</div>
            </div>
            <div class="captcha-main-area">
                <div id="captcha-grid" class="captcha-grid"></div>
                <div class="captcha-slider-box">
                    <button type="button" class="slider-adjust-btn" id="slider-up">▲</button>
                    <input type="range" id="captcha-nav-slider" min="0" max="249995" value="0" step="1" />
                    <button type="button" class="slider-adjust-btn" id="slider-down">▼</button>
                </div>
            </div>
        </div>
        <div class="captcha-footer">
            <button type="button" id="close-captcha-btn" class="cancel-btn">取消</button>
        </div>
    </div>
</div>

<style>
    :root {
        --primary: #1677ff;
        --error: #ff4d4f;
        --success: #52c41a;
        --border: #d9d9d9;
        --text: #262626;
        --text-subtle: #8c8c8c;
    }

    .login-container { width: 100%; max-width: 400px; margin: 12vh auto; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
    .login-card { background: #fff; padding: 32px; border-radius: 8px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); position: relative; border: 1px solid #f0f0f0; display: flex; flex-direction: column; }
    
    .login-header h2 { margin: 0 0 4px 0; font-size: 22px; color: var(--text); }
    .login-header p { margin: 0 0 28px 0; color: var(--text-subtle); font-size: 13px; }

    .form-item { margin-bottom: 16px; }
    .form-item label { display: block; margin-bottom: 6px; font-size: 13px; font-weight: 500; color: var(--text); }
    
    input { width: 100%; height: 38px; border: 1px solid var(--border); padding: 0 12px; border-radius: 4px; font-size: 14px; transition: all 0.2s; box-sizing: border-box; }
    input:focus { border-color: var(--primary); outline: none; box-shadow: 0 0 0 2px rgba(22,119,255,0.1); }
    input[readonly] { background: #f5f5f5; color: #595959; cursor: default; }

    /* 步进器样式 */
    .stepper-input { display: flex; align-items: center; border: 1px solid var(--border); border-radius: 4px; overflow: hidden; }
    .stepper-input input { border: none; text-align: center; padding: 0; flex: 1; border-left: 1px solid var(--border); border-right: 1px solid var(--border); }
    .stepper-input input:focus { box-shadow: none; }
    .step-btn { width: 40px; height: 38px; background: #fafafa; border: none; cursor: pointer; color: #595959; font-size: 18px; transition: background 0.2s; }
    .step-btn:hover { background: #f0f0f0; color: var(--primary); }
    .step-btn:active { background: #e8e8e8; }

    .input-with-action { display: flex; gap: 8px; }
    .input-with-action input { flex: 1; }
    
    .inline-button { flex-shrink: 0; white-space: nowrap; min-width: 90px; height: 38px; padding: 0 12px; background: #fff; border: 1px solid var(--border); border-radius: 4px; font-size: 13px; cursor: pointer; color: #595959; transition: all 0.2s; }
    .inline-button:hover:not(:disabled) { color: var(--primary); border-color: var(--primary); }
    .inline-button:disabled { color: #bfbfbf; background: #f5f5f5; cursor: not-allowed; }

    .primary-button { width: 100%; height: 40px; background: var(--primary); color: #fff; border: none; border-radius: 4px; cursor: pointer; font-weight: 500; font-size: 15px; margin-top: 4px; transition: background 0.2s; }
    .primary-button:hover { background: #4096ff; }
    
    .secondary-button { width: 100%; height: 40px; background: #fff; border: 1px solid var(--border); border-radius: 4px; cursor: pointer; margin-top: 20px; font-size: 14px; color: #595959; }

    .form-toggle { margin-top: 16px; text-align: center; }
    .form-toggle a { font-size: 13px; color: var(--primary); text-decoration: none; }
    .form-toggle a:hover { text-decoration: underline; }

    .alert-container { min-height: 48px; }
    .alert { width: 100%; padding: 10px 12px; border-radius: 4px; font-size: 13px; text-align: center; border: 1px solid transparent; box-sizing: border-box; }
    .alert.error { background: #fff2f0; color: var(--error); border-color: #ffccc7; }
    .alert.success { background: #f6ffed; color: var(--success); border-color: #b7eb8f; }
    .hidden { display: none !important; }

    /* 验证码弹窗优化 */
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.45); z-index: 2000; display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px); }
    .captcha-popup { background: #fff; border-radius: 8px; width: 360px; box-shadow: 0 15px 40px rgba(0,0,0,0.18); display: flex; flex-direction: column; overflow: hidden; border: 1px solid #e8e8e8; }
    .captcha-title { padding: 14px 20px; background: #fff; border-bottom: 1px solid #f0f0f0; display: flex; justify-content: space-between; align-items: center; font-weight: 600; font-size: 15px; color: var(--text); }
    .close-x { background: none; border: none; color: #bfbfbf; font-size: 22px; cursor: pointer; transition: color 0.2s; }
    .captcha-header { padding: 20px; background: #fafafa; border-bottom: 1px solid #f0f0f0; display: flex; flex-direction: column; align-items: center; }
    .captcha-image-box { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; width: 100%; justify-content: center; }
    #captcha-img { height: 48px; border: 1px solid #d9d9d9; border-radius: 4px; background: #fff; }
    .refresh-btn { background: #fff; border: 1px solid #d9d9d9; color: var(--text-subtle); cursor: pointer; font-size: 18px; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; transition: all 0.2s; }
    .refresh-btn:hover { color: var(--primary); border-color: var(--primary); }
    .captcha-guide { font-size: 12px; color: #8c8c8c; text-align: center; }
    .captcha-main-area { flex: 1; display: flex; padding: 16px; gap: 16px; overflow: hidden; background: #fff; }
    .captcha-grid { flex: 1; display: grid; grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(5, 1fr); gap: 8px; }
    .captcha-btn { background: #fff; border: 1px solid #f0f0f0; border-radius: 4px; font-size: 13px; color: #595959; cursor: pointer; font-family: 'Roboto Mono', monospace; display: flex; align-items: center; justify-content: center; }
    .captcha-btn:hover { border-color: var(--primary); color: var(--primary); background: rgba(22,119,255,0.02); }
    
    .captcha-slider-box { width: 28px; display: flex; flex-direction: column; align-items: center; gap: 8px; padding: 2px 0; }
    .slider-adjust-btn { width: 24px; height: 24px; background: #fff; border: 1px solid #d9d9d9; border-radius: 4px; font-size: 10px; cursor: pointer; color: #8c8c8c; display: flex; align-items: center; justify-content: center; }
    .slider-adjust-btn:hover { border-color: var(--primary); color: var(--primary); }
    #captcha-nav-slider { -webkit-appearance: none; width: 6px; flex: 1; background: #f0f0f0; border-radius: 3px; outline: none; writing-mode: bt-lr; -webkit-appearance: slider-vertical; appearance: slider-vertical; transform: rotate(180deg); }
    #captcha-nav-slider::-webkit-slider-thumb { -webkit-appearance: none; width: 18px; height: 18px; background: #fff; border: 2px solid var(--primary); border-radius: 50%; cursor: pointer; box-shadow: 0 2px 6px rgba(0,0,0,0.1); }
    
    .captcha-footer { padding: 12px 20px; border-top: 1px solid #f0f0f0; text-align: center; background: #fafafa; }
    .cancel-btn { width: 80px; height: 32px; background: #fff; border: 1px solid #d9d9d9; border-radius: 4px; color: #595959; cursor: pointer; font-size: 13px; }

    .spinner { width: 28px; height: 28px; border: 2px solid #f3f3f3; border-top: 2px solid var(--primary); border-radius: 50%; animation: spin 1s linear infinite; }
    @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    #loading-overlay { position: absolute; top: 0; left: 0; right: 0; bottom: 0; background: rgba(255,255,255,0.6); display: flex; align-items: center; justify-content: center; z-index: 1000; border-radius: 8px; }

    .dash-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; padding-bottom: 16px; border-bottom: 1px solid #f0f0f0; }
    .user-avatar { width: 48px; height: 48px; background: var(--primary); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 20px; font-weight: 600; }
    .user-info h3 { margin: 0; font-size: 16px; color: var(--text); }
    .user-info p { margin: 2px 0 0 0; font-size: 12px; color: var(--text-subtle); }
</style>

<script>
    import { foolsignup } from '../lib/pb/auth.js';
    import { create, get } from '@github/webauthn-json';
    const authpb = foolsignup.auth.v1;

    document.addEventListener('DOMContentLoaded', () => {
        const form = document.getElementById('uip-form') as HTMLFormElement;
        const authView = document.getElementById('auth-view');
        const twofaView = document.getElementById('2fa-view');
        const twofaBtn = document.getElementById('webauthn-btn') as HTMLButtonElement;
        const twofaMsg = document.getElementById('2fa-msg');
        const backToLogin = document.getElementById('back-to-login');
        
        const userInput = document.getElementById('username') as HTMLInputElement;
        const toggleLink = document.getElementById('toggle-link');
        const sendCodeBtn = document.getElementById('send-code-btn') as HTMLButtonElement;
        const emailInput = document.getElementById('email') as HTMLInputElement;
        const ageInput = document.getElementById('age') as HTMLInputElement;
        const passwordInput = document.getElementById('password') as HTMLInputElement;
        const confirmPasswordInput = document.getElementById('confirm-password') as HTMLInputElement;
        const confirmPasswordField = document.getElementById('confirm-password-field');
        
        const captchaModal = document.getElementById('captcha-modal');
        const captchaImg = document.getElementById('captcha-img') as HTMLImageElement;
        const captchaGrid = document.getElementById('captcha-grid');
        const captchaSlider = document.getElementById('captcha-nav-slider') as HTMLInputElement;

        const successAlert = document.getElementById('success-alert');
        const errorAlert = document.getElementById('error-alert');
        const errorText = document.getElementById('error-text');
        const loading = document.getElementById('loading-overlay');

        let isLoginMode = true; 
        let tempToken = "";
        let isSetup = false;
        const apiUrl = import.meta.env.PUBLIC_API_URL || '';
        const traceId = Math.random().toString(36).substring(2, 15);

        const dashboardView = document.getElementById('dashboard-view');
        const dashUsername = document.getElementById('dash-username');
        const logoutBtn = document.getElementById('logout-btn');

        // 年龄步进器逻辑：移除正数限制，允许负数
        document.getElementById('age-minus').addEventListener('click', () => {
            const val = parseInt(ageInput.value) || 0;
            ageInput.value = (val - 1).toString();
        });
        document.getElementById('age-plus').addEventListener('click', () => {
            const val = parseInt(ageInput.value) || 0;
            ageInput.value = (val + 1).toString();
        });

        // 验证码滑动条微调逻辑
        document.getElementById('slider-up').addEventListener('click', () => {
            const val = parseInt(captchaSlider.value);
            if (val > 0) {
                captchaSlider.value = (val - 1).toString();
                renderGrid();
            }
        });
        document.getElementById('slider-down').addEventListener('click', () => {
            const val = parseInt(captchaSlider.value);
            const max = parseInt(captchaSlider.max);
            if (val < max) {
                captchaSlider.value = (val + 1).toString();
                renderGrid();
            }
        });

        async function checkLogin() {
            try {
                const res = await fetch(`${apiUrl}/api/me`, { credentials: 'include', headers: { 'X-Trace-Id': traceId } });
                if (res.status === 200) {
                    const buffer = await res.arrayBuffer();
                    const result = authpb.GetMeResponse.decode(new Uint8Array(buffer));
                    if (result.code === 200) {
                        authView.classList.add('hidden');
                        dashboardView.classList.remove('hidden');
                        dashUsername.textContent = result.data.username;
                    }
                }
            } catch (e) { console.error("Check login failed", e); }
        }
        checkLogin();

        logoutBtn.addEventListener('click', async () => {
            await fetch(`${apiUrl}/api/logout`, { credentials: 'include', headers: { 'X-Trace-Id': traceId } });
            location.reload();
        });

        function hideAlerts() {
            errorAlert.classList.add('hidden');
            successAlert.classList.add('hidden');
        }

        form.addEventListener('input', hideAlerts);

        function updateUI() {
            hideAlerts();
            form.reset();
            authView.classList.remove('hidden');
            twofaView.classList.add('hidden');

            document.getElementById('form-title').textContent = isLoginMode ? "账号登录" : "账号注册";
            document.getElementById('email-field').classList.toggle('hidden', isLoginMode);
            document.getElementById('code-field').classList.toggle('hidden', isLoginMode);
            document.getElementById('age-field').classList.toggle('hidden', isLoginMode);
            confirmPasswordField.classList.toggle('hidden', isLoginMode);
            toggleLink.textContent = isLoginMode ? "没有账号？点击注册" : "已有账号？点击登录";
            
            if (!isLoginMode) {
                userInput.value = `User_${Math.floor(Math.random()*899999+100000)}`;
                userInput.readOnly = true;
                userInput.tabIndex = -1;
                ageInput.value = ""; // 移除默认值 18
            } else {
                userInput.value = "";
                userInput.readOnly = false;
                userInput.tabIndex = 0;
                userInput.placeholder = "请输入您的用户名";
            }
        }
        updateUI();

        toggleLink.addEventListener('click', (e) => {
            e.preventDefault();
            isLoginMode = !isLoginMode;
            updateUI();
        });

        backToLogin.addEventListener('click', (e) => {
            e.preventDefault();
            updateUI();
        });

        function renderGrid() {
            const startIdx = parseInt(captchaSlider.value) * 4;
            let html = '';
            for (let i = 0; i < 20; i++) {
                const num = startIdx + i;
                const val = num.toString().padStart(6, '0');
                html += `<button type="button" class="captcha-btn">${val}</button>`;
            }
            captchaGrid.innerHTML = html;
        }
        captchaSlider.addEventListener('input', renderGrid);

        async function fetchNewCaptcha() {
            try {
                const res = await fetch(`${apiUrl}/api/captcha`);
                const buffer = await res.arrayBuffer();
                const json = authpb.GetCaptchaResponse.decode(new Uint8Array(buffer));
                if (json.code === 200) {
                    captchaImg.src = json.data.image;
                    captchaImg.dataset.key = json.data.captchaKey;
                }
            } catch (e) { console.error(e); }
        }

        document.getElementById('refresh-captcha').addEventListener('click', fetchNewCaptcha);

        captchaGrid.addEventListener('click', (e) => {
            const btn = (e.target as HTMLElement).closest('.captcha-btn') as HTMLButtonElement;
            if (!btn) return;
            captchaModal.classList.add('hidden');
            executeSendCode(btn.textContent, captchaImg.dataset.key);
        });

        const closeFunc = () => captchaModal.classList.add('hidden');
        document.getElementById('close-captcha-x').addEventListener('click', closeFunc);
        document.getElementById('close-captcha-btn').addEventListener('click', closeFunc);

        let countdownTimer: any = null;
        function startCountdown() {
            let seconds = 60;
            sendCodeBtn.disabled = true;
            sendCodeBtn.textContent = `${seconds}s`;
            if (countdownTimer) clearInterval(countdownTimer);
            countdownTimer = setInterval(() => {
                seconds--;
                if (seconds <= 0) {
                    clearInterval(countdownTimer);
                    sendCodeBtn.disabled = false;
                    sendCodeBtn.textContent = "发送验证码";
                } else {
                    sendCodeBtn.textContent = `${seconds}s`;
                }
            }, 1000);
        }

        async function executeSendCode(val, key) {
            loading.classList.remove('hidden');
            try {
                const req = authpb.SendEmailCodeRequest.create({ email: emailInput.value, captchaKey: key, captchaValue: val });
                const res = await fetch(`${apiUrl}/api/send-code`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-protobuf', 'X-Trace-Id': traceId },
                    body: authpb.SendEmailCodeRequest.encode(req).finish()
                });
                const result = await handleFetchResponse(res, authpb.SendEmailCodeResponse);
                showSuccess(result.msg || "已发送");
                startCountdown();
            } catch (e) { 
                showError(e.message || "发送失败", (e as any).code, (e as any).traceId); 
            } finally { loading.classList.add('hidden'); }
        }

        async function verifyPoW(input) {
            const msgUint8 = new TextEncoder().encode(input);
            const hashBuffer = await crypto.subtle.digest('SHA-256', msgUint8);
            const hashArray = Array.from(new Uint8Array(hashBuffer));
            const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
            return hashHex.startsWith('00000');
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            hideAlerts();
            const formData = new FormData(form);
            const rawData = Object.fromEntries(formData.entries());

            loading.classList.remove('hidden');
            try {
                let body, responseClass;
                if (isLoginMode) {
                    if (!rawData.username) { showError("请输入用户名"); return; }
                    if (!rawData.password) { showError("请输入密码"); return; }
                    const req = authpb.LoginRequest.fromObject({ username: rawData.username, password: rawData.password });
                    body = authpb.LoginRequest.encode(req).finish();
                    responseClass = authpb.LoginResponse;
                } else {
                    if (!rawData.email) { showError("请输入邮箱地址"); return; }
                    if (!rawData.age) { showError("请输入年龄"); return; }
                    if (!rawData.password) { showError("请输入密码"); return; }
                    if (rawData.password !== rawData['confirm-password']) { showError("两次输入的密码不一致"); return; }
                    if (!rawData.code) { showError("请输入 PoW 验证码"); return; }
                    const isValid = await verifyPoW(rawData.code as string);
                    if (!isValid) { showError("算力证明无效：哈希摘要未满足难度目标"); return; }
                    const req = authpb.RegisterRequest.fromObject({
                        username: rawData.username, email: rawData.email, age: parseInt(rawData.age as string),
                        password: rawData.password, code: rawData.code
                    });
                    body = authpb.RegisterRequest.encode(req).finish();
                    responseClass = authpb.RegisterResponse;
                }

                const response = await fetch(`${apiUrl}${isLoginMode ? '/api/login' : '/api/register'}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-protobuf', 'X-Trace-Id': traceId },
                    body: body,
                    credentials: 'include'
                });
                const result = await handleFetchResponse(response, responseClass);
                
                if (isLoginMode) {
                    const { setup_2fa, require_2fa, tempToken: tToken } = result.data || {};
                    if (setup_2fa || require_2fa) {
                        tempToken = tToken;
                        isSetup = setup_2fa;
                        authView.classList.add('hidden');
                        twofaView.classList.remove('hidden');
                        twofaMsg.textContent = isSetup ? "首次登录，请设置生物识别凭证" : "请使用生物识别验证身份";
                        twofaBtn.textContent = isSetup ? "立即设置" : "立即验证";
                    } else {
                        location.reload();
                    }
                } else {
                    isLoginMode = true;
                    updateUI();
                    showSuccess("注册成功，请登录");
                }
            } catch (e) {
                showError(e.message || "请求失败", (e as any).code, (e as any).traceId);
            } finally {
                loading.classList.add('hidden');
            }
        });

        twofaBtn.addEventListener('click', async () => {
            hideAlerts();
            loading.classList.remove('hidden');
            try {
                if (isSetup) {
                    const res = await fetch(`${apiUrl}/api/webauthn/register/options`, { 
                        credentials: 'include', headers: { 'X-Trace-Id': traceId }
                    });
                    const json = await handleFetchResponse(res, authpb.GetWebAuthnRegistrationOptionsResponse);
                    const credential = await create(JSON.parse(json.optionsJson));
                    const vRes = await fetch(`${apiUrl}/api/webauthn/register/verify`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-protobuf', 'X-Trace-Id': traceId },
                        body: authpb.VerifyWebAuthnRegistrationRequest.encode({ credentialJson: JSON.stringify(credential) }).finish(),
                        credentials: 'include'
                    });
                    await handleFetchResponse(vRes, authpb.VerifyWebAuthnRegistrationResponse);
                    location.reload();
                } else {
                    const res = await fetch(`${apiUrl}/api/webauthn/login/options`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-protobuf', 'X-Trace-Id': traceId },
                        body: authpb.GetWebAuthnLoginOptionsRequest.encode({ tempToken }).finish(),
                        credentials: 'include'
                    });
                    const json = await handleFetchResponse(res, authpb.GetWebAuthnLoginOptionsResponse);
                    const credential = await get(JSON.parse(json.optionsJson));
                    const vRes = await fetch(`${apiUrl}/api/webauthn/login/verify`, {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-protobuf', 'X-Trace-Id': traceId },
                        body: authpb.VerifyWebAuthnLoginRequest.encode({ tempToken, credentialJson: JSON.stringify(credential) }).finish(),
                        credentials: 'include'
                    });
                    await handleFetchResponse(vRes, authpb.VerifyWebAuthnLoginResponse);
                    location.reload();
                }
            } catch (e) { 
                showError(e.message || "验证失败", (e as any).code, (e as any).traceId); 
            } finally { 
                loading.classList.add('hidden'); 
            }
        });

        function showError(msg, code = 0, tid = "") { 
            loading.classList.add('hidden');
            let displayMsg = msg;
            if (tid && (code >= 500 || code === 0) && !msg.includes("请输入") && !msg.includes("一致")) {
                displayMsg += ` (ID: ${tid})`;
            }
            errorText.textContent = displayMsg; 
            errorAlert.classList.remove('hidden'); 
            successAlert.classList.add('hidden');
            errorAlert.scrollIntoView({ behavior: 'smooth', block: 'end' });
        }

        function showSuccess(msg) { 
            successAlert.textContent = msg; 
            successAlert.classList.remove('hidden'); 
            errorAlert.classList.add('hidden');
        }

        async function handleFetchResponse(response, responseClass) {
            const contentType = response.headers.get('content-type');
            const isProto = contentType && contentType.includes('application/x-protobuf');
            if (isProto) {
                const buffer = await response.arrayBuffer();
                const decoded = responseClass.decode(new Uint8Array(buffer));
                if (!response.ok || (decoded.code && decoded.code !== 200)) {
                    const err = new Error(decoded.msg || `服务器错误 (${response.status})`);
                    (err as any).code = decoded.code || response.status;
                    (err as any).traceId = decoded.traceId;
                    throw err;
                }
                return decoded;
            }
            if (!response.ok) {
                const text = await response.text();
                const err = new Error(text || `请求失败 (${response.status})`);
                (err as any).code = response.status;
                throw err;
            }
            const buffer = await response.arrayBuffer();
            return responseClass.decode(new Uint8Array(buffer));
        }

        sendCodeBtn.addEventListener('click', () => { 
            if (emailInput.value) { 
                hideAlerts(); 
                fetchNewCaptcha(); 
                captchaModal.classList.remove('hidden'); 
                renderGrid(); 
            } else showError("请输入邮箱地址"); 
        });
    });
</script>
