    .twofa-icon-box {
        position: relative;
        width: 144px;
        height: 144px;
        margin: 6px auto 20px;
        border-radius: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        background:
            radial-gradient(circle at 14% 16%, rgba(11, 106, 103, 0.2), transparent 48%),
            radial-gradient(circle at 86% 14%, rgba(245, 158, 11, 0.18), transparent 44%),
            linear-gradient(160deg, rgba(255, 255, 255, 0.92), rgba(236, 254, 255, 0.72));
        border: 1px solid rgba(11, 106, 103, 0.16);
        box-shadow:
            inset 0 1px 0 rgba(255, 255, 255, 0.78),
            0 14px 30px rgba(11, 106, 103, 0.14);
        animation: shield-float 2.6s ease-in-out infinite;
    }

    .twofa-icon-box::before {
        content: '';
        position: absolute;
        inset: 11px;
        border-radius: 24px;
        border: 1px solid rgba(11, 106, 103, 0.18);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.55), rgba(255, 255, 255, 0.1));
        pointer-events: none;
    }

    .twofa-icon-box::after {
        content: '';
        position: absolute;
        left: 50%;
        top: 20px;
        width: 56px;
        height: 10px;
        transform: translateX(-50%);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.6);
        filter: blur(0.5px);
        pointer-events: none;
    }

    .shield-core {
        position: relative;
        z-index: 1;
        width: 58px;
        height: 68px;
        background: linear-gradient(180deg, rgba(11, 106, 103, 0.95), rgba(10, 79, 77, 0.92));
        clip-path: polygon(50% 0, 88% 14%, 88% 48%, 50% 100%, 12% 48%, 12% 14%);
        box-shadow: 0 10px 20px rgba(10, 79, 77, 0.34);
    }

    .shield-core::before {
        content: '';
        position: absolute;
        inset: 6px 8px 10px;
        clip-path: polygon(50% 0, 88% 14%, 88% 48%, 50% 100%, 12% 48%, 12% 14%);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.34), rgba(255, 255, 255, 0.06));
    }

    .shield-check {
        position: absolute;
        z-index: 2;
        width: 18px;
        height: 10px;
        border-left: 3px solid #ecfeff;
        border-bottom: 3px solid #ecfeff;
        transform: translate(2px, 8px) rotate(-45deg);
        box-shadow: 0 2px 8px rgba(15, 23, 42, 0.2);
    }

    .shield-check::after {
        content: '';
        position: absolute;
        right: -20px;
        top: -22px;
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: rgba(245, 158, 11, 0.5);
        box-shadow: 0 0 0 8px rgba(245, 158, 11, 0.12);
    }

    .dash-header {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-bottom: 24px;
        padding-bottom: 18px;
        border-bottom: 1px solid rgba(148, 163, 184, 0.2);
    }

    .user-avatar {
        width: 56px;
        height: 56px;
        border-radius: 20px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        color: white;
        font-size: 1.3rem;
        font-weight: 800;
        box-shadow: 0 18px 34px rgba(11, 106, 103, 0.22);
    }

    .user-info h3 {
        margin: 0;
        font-size: 1.15rem;
        color: var(--text);
    }

    .user-info p {
        margin: 3px 0 0;
