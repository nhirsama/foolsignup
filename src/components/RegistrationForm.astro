    }

    .hidden {
        display: none !important;
    }

    #twofa-view {
        padding: clamp(18px, 2.2vw, 24px);
        border-radius: 26px;
        border: 1px solid rgba(11, 106, 103, 0.16);
        background:
            radial-gradient(circle at 86% 12%, rgba(245, 158, 11, 0.17), transparent 34%),
            linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(236, 254, 255, 0.6));
