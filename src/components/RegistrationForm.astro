<div class="login-shell">
    <section class="login-container">
        <div class="brand-panel">
            <div class="brand-orb brand-orb-a"></div>
            <div class="brand-orb brand-orb-b"></div>
            <div class="brand-grid"></div>
            <div class="brand-stack">
                <div class="stack-card stack-card-a"></div>
                <div class="stack-card stack-card-b"></div>
                <div class="stack-card stack-card-c"></div>
            </div>
        </div>

        <div class="login-card">
            <div class="card-glow"></div>
            <div class="card-confetti card-confetti-a"></div>
            <div class="card-confetti card-confetti-b"></div>
            <div class="card-confetti card-confetti-c"></div>
            <div class="language-toolbar">
                <div class="language-picker" id="language-picker">
                    <button
                        type="button"
                        id="language-trigger"
                        class="language-trigger"
                        aria-haspopup="listbox"
                        aria-expanded="false"
                    >
                        <span id="language-current" class="language-current">Espanol</span>
                        <span class="language-caret" aria-hidden="true"></span>
                    </button>
                    <div id="language-menu" class="language-menu hidden">
                        <div id="language-list" class="language-list" role="listbox"></div>
                    </div>
                </div>
            </div>
            <div id="auth-view">
                <div class="login-header">
                    <h2 id="form-title">Iniciar sesion</h2>
                    <p id="form-subtitle">Gestiona tu identidad y permisos de acceso</p>
                </div>

                <form id="uip-form">
                    <div class="form-item" id="username-field">
                        <label for="username" data-i18n="label.username">Usuario</label>
                        <input
                            type="text"
                            id="username"
                            name="username"
                            placeholder="Introduce tu usuario"
                            data-i18n-placeholder="placeholder.username.login"
                        />
                    </div>

                    <div class="form-item hidden" id="email-field">
                        <label for="email" data-i18n="label.email">Correo electronico</label>
                        <div class="input-with-action">
                            <input
                                type="email"
                                id="email"
                                name="email"
                                autocomplete="email"
                                spellcheck="false"
                                placeholder="tu@correo.com"
                                data-i18n-placeholder="placeholder.email"
                            />
                            <button type="button" id="send-code-btn" class="inline-button">Enviar codigo</button>
                        </div>
                    </div>

                    <div class="form-item hidden" id="code-field">
                        <label for="code" data-i18n="label.code">Codigo de verificacion</label>
                        <input
                            type="text"
                            id="code"
                            name="code"
                            placeholder="Introduce el codigo"
                            data-i18n-placeholder="placeholder.code"
                        />
                    </div>

                    <div class="form-item hidden" id="age-field">
                        <label for="age" data-i18n="label.age">Edad</label>
                        <div class="stepper-input">
                            <button type="button" class="step-btn" id="age-minus">-</button>
                            <input
                                type="number"
                                id="age"
                                name="age"
                                step="1"
                                value=""
                                placeholder="Selecciona tu edad"
                                data-i18n-placeholder="placeholder.age"
                                readonly
                            />
                            <button type="button" class="step-btn" id="age-plus">+</button>
                        </div>
                    </div>

                    <div class="form-item" id="password-field">
                        <label for="password" data-i18n="label.password">Contrasena</label>
                        <input
                            type="password"
                            id="password"
                            name="password"
                            placeholder="Define una contrasena"
                            data-i18n-placeholder="placeholder.password"
                        />
                    </div>

                    <div class="password-complexity hidden" id="password-complexity-box" aria-hidden="true">
                        <div class="password-complexity-spectrum">
                            <span class="password-complexity-fill is-idle" id="password-complexity-fill"></span>
                        </div>
                    </div>

                    <div class="form-item hidden" id="confirm-password-field">
                        <label for="confirm-password" data-i18n="label.confirmPassword">Confirmar contrasena</label>
                        <input
                            type="password"
                            id="confirm-password"
                            name="confirm-password"
                            placeholder="Introduce de nuevo la contrasena"
                            data-i18n-placeholder="placeholder.confirmPassword"
                        />
                    </div>

                    <div class="form-actions" id="form-actions">
                        <button type="submit" id="submit-btn" class="primary-button">Enviar</button>
                        <button type="button" id="register-back-btn" class="secondary-button hidden">Volver al paso anterior</button>
                    </div>

                    <div class="form-toggle">
                        <a href="#" id="toggle-link">No tienes cuenta? Registrate</a>
                    </div>
                </form>
            </div>

            <div id="twofa-view" class="hidden">
                <div class="login-header">
                    <h2 id="twofa-title" data-i18n="twofa.title">Verificacion en dos pasos</h2>
                    <p id="twofa-msg">Verifica tu identidad con biometria</p>
                </div>
                <div class="twofa-icon-box" aria-hidden="true">
                    <span class="shield-core"></span>
                    <span class="shield-check"></span>
                </div>
                <button id="webauthn-btn" class="primary-button">Verificar ahora</button>
                <div class="form-toggle">
                    <a href="#" id="back-to-login" data-i18n="twofa.backToLogin">Volver al acceso normal</a>
                </div>
            </div>

            <div id="dashboard-view" class="hidden">
                <div class="dash-header">
                    <div class="user-avatar">U</div>
                    <div class="user-info">
                        <h3 id="dash-username">...</h3>
                        <p data-i18n="dashboard.online">En linea</p>
                    </div>
                </div>

                <div class="april-fool-notice">
                    <p class="notice-title" data-i18n="dashboard.notice.title">Feliz April Fools!</p>
                    <p data-i18n="dashboard.notice.body">Este es un proyecto de broma que intencionalmente empeora la experiencia de registro.</p>
                    <p>
                        <span data-i18n="dashboard.notice.sourcePrefix">Codigo fuente:</span>
                        <a href="https://github.com/nhirsama/foolsignup" target="_blank">https://github.com/nhirsama/foolsignup</a>
                    </p>
                    <p class="notice-warn" data-i18n="dashboard.notice.warn">Aviso: si usaste una contrasena habitual, cambiala tambien en otros sitios.</p>
                </div>

                <button class="secondary-button" id="logout-btn" data-i18n="dashboard.logout">Cerrar sesion segura</button>
            </div>

            <div id="alert-container" class="alert-container">
                <div id="error-alert" class="alert error hidden">
                    <span id="error-text"></span>
                </div>
                <div id="success-alert" class="alert success hidden"></div>
            </div>

            <div id="loading-overlay" class="hidden"><div class="spinner"></div></div>
        </div>
    </section>
</div>

<div id="captcha-modal" class="modal-overlay hidden">
    <div class="captcha-popup">
        <div class="captcha-title">
            <span data-i18n="captcha.title">Verificacion de seguridad</span>
            <button id="close-captcha-x" class="close-x">&times;</button>
        </div>
        <div class="captcha-body">
            <div class="captcha-header">
                <div class="captcha-image-box">
                    <img id="captcha-img" src="" alt="CAPTCHA" data-i18n-alt="captcha.alt" />
                    <button id="refresh-captcha" class="refresh-btn" title="Actualizar captcha" data-i18n-title="captcha.refreshTitle">⟳</button>
                </div>
                <div class="captcha-guide" data-i18n="captcha.guide">Usa el deslizador y pulsa el numero que coincide con la imagen.</div>
            </div>
            <div class="captcha-main-area">
                <div id="captcha-grid" class="captcha-grid"></div>
                <div class="captcha-slider-box">
                    <button type="button" class="slider-adjust-btn" id="slider-up">▲</button>
                    <input type="range" id="captcha-nav-slider" min="0" max="249995" value="0" step="1" />
                    <button type="button" class="slider-adjust-btn" id="slider-down">▼</button>
                </div>
            </div>
        </div>
        <div class="captcha-footer">
            <button type="button" id="close-captcha-btn" class="cancel-btn" data-i18n="captcha.cancel">Cancelar</button>
        </div>
    </div>
</div>

<style>
    :root {
        --primary: #0b6a67;
        --primary-strong: #0a4f4d;
        --accent: #f59e0b;
        --surface: rgba(255, 255, 255, 0.76);
        --surface-strong: rgba(255, 255, 255, 0.9);
        --surface-border: rgba(15, 23, 42, 0.11);
        --text: #0f172a;
        --text-subtle: #5b6475;
        --error: #b91c1c;
        --success: #166534;
        --shadow-xl: 0 28px 90px rgba(15, 23, 42, 0.16);
    }

    .login-shell {
        width: 100%;
        animation: shell-enter 520ms ease both;
    }

    .login-container {
        width: min(1180px, 100%);
        margin: 0 auto;
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(360px, 460px);
        gap: clamp(20px, 3.2vw, 36px);
        align-items: stretch;
        position: relative;
        z-index: 1;
    }

    .brand-panel,
    .login-card {
        position: relative;
        overflow: hidden;
        border: 1px solid var(--surface-border);
        box-shadow: var(--shadow-xl);
        backdrop-filter: blur(18px);
    }

    .brand-panel {
        min-height: 700px;
        border-radius: 34px;
        background:
            radial-gradient(circle at 16% 20%, rgba(11, 106, 103, 0.26), transparent 30%),
            radial-gradient(circle at 84% 78%, rgba(245, 158, 11, 0.2), transparent 28%),
            linear-gradient(148deg, rgba(255, 255, 255, 0.82), rgba(236, 254, 255, 0.34));
    }

    .brand-panel::before {
        content: '';
        position: absolute;
        inset: 0;
        background:
            linear-gradient(rgba(15, 23, 42, 0.06) 1px, transparent 1px),
            linear-gradient(90deg, rgba(15, 23, 42, 0.06) 1px, transparent 1px);
        background-size: 30px 30px;
        mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.8), transparent 85%);
        opacity: 0.44;
    }

    .brand-orb {
        position: absolute;
        border-radius: 999px;
        filter: blur(6px);
        pointer-events: none;
    }

    .brand-orb-a {
        width: 240px;
        height: 240px;
        top: 64px;
        left: 52px;
        background: radial-gradient(circle, rgba(11, 106, 103, 0.26), rgba(11, 106, 103, 0.04) 70%, transparent 74%);
    }

    .brand-orb-b {
        width: 300px;
        height: 300px;
        right: 40px;
        bottom: 44px;
        background: radial-gradient(circle, rgba(245, 158, 11, 0.2), rgba(245, 158, 11, 0.05) 64%, transparent 72%);
    }

    .brand-grid {
        position: absolute;
        inset: 0;
    }

    .brand-stack {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .stack-card {
        position: absolute;
        width: min(82%, 430px);
        aspect-ratio: 1.06;
        border-radius: 34px;
        border: 1px solid rgba(255, 255, 255, 0.45);
        backdrop-filter: blur(9px);
        box-shadow: 0 24px 60px rgba(15, 23, 42, 0.13);
    }

    .stack-card-a {
        transform: rotate(-13deg) translate(-34px, 12px);
        background: linear-gradient(160deg, rgba(255, 255, 255, 0.6), rgba(255, 255, 255, 0.16));
    }

    .stack-card-b {
        transform: rotate(10deg) translate(42px, -16px);
        background: linear-gradient(160deg, rgba(236, 254, 255, 0.8), rgba(255, 255, 255, 0.2));
    }

    .stack-card-c {
        transform: rotate(-1.6deg);
        background:
            linear-gradient(138deg, rgba(255, 255, 255, 0.94), rgba(255, 255, 255, 0.42)),
            radial-gradient(circle at top right, rgba(11, 106, 103, 0.16), transparent 34%);
    }

    .stack-card-c::before,
    .stack-card-c::after,
    .stack-card-a::before,
    .stack-card-a::after {
        content: '';
        position: absolute;
        border-radius: 999px;
    }

    .stack-card-c::before {
        left: 32px;
        top: 36px;
        width: 36%;
        height: 14px;
        background: rgba(15, 23, 42, 0.12);
    }

    .stack-card-c::after {
        left: 32px;
        top: 62px;
        width: 52%;
        height: 9px;
        background: rgba(15, 23, 42, 0.08);
    }

    .stack-card-a::before {
        inset: 28px 28px auto;
        height: 98px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.32);
    }

    .stack-card-a::after {
        inset: auto 28px 28px;
        height: 64px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.36);
    }

    .login-card {
        background: linear-gradient(180deg, var(--surface-strong), var(--surface));
        border-radius: 34px;
        min-height: 700px;
        padding: clamp(24px, 3vw, 34px);
        display: flex;
        flex-direction: column;
        justify-content: center;
        isolation: isolate;
        overflow: visible;
    }

    .language-toolbar {
        position: relative;
        z-index: 3;
        display: flex;
        align-self: flex-end;
        justify-content: flex-end;
        align-items: center;
        margin-bottom: 14px;
    }

    .language-picker {
        position: relative;
        width: clamp(180px, 28vw, 240px);
    }

    .language-trigger {
        width: 100%;
        height: 40px;
        padding: 0 12px;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.32);
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.95));
        color: #334155;
        font-size: 0.82rem;
        font-weight: 600;
        font-family: inherit;
        cursor: pointer;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.64), 0 8px 16px rgba(15, 23, 42, 0.07);
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease, background 0.2s ease;
        display: grid;
        grid-template-columns: minmax(0, 1fr) 14px;
        align-items: center;
        gap: 6px;
        text-align: left;
    }

    .language-trigger:hover {
        border-color: rgba(11, 106, 103, 0.34);
        transform: translateY(-1px);
    }

    .language-trigger:focus-visible {
        outline: none;
        border-color: rgba(11, 106, 103, 0.54);
        box-shadow: 0 0 0 3px rgba(11, 106, 103, 0.11), 0 10px 22px rgba(11, 106, 103, 0.14);
        transform: translateY(-1px);
    }

    .language-current {
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        color: #0f172a;
        font-size: 0.84rem;
        font-weight: 600;
    }

    .language-caret {
        width: 9px;
        height: 9px;
        border-right: 2px solid rgba(11, 106, 103, 0.74);
        border-bottom: 2px solid rgba(11, 106, 103, 0.74);
        transform: rotate(45deg) translateY(-1px);
        justify-self: end;
        transition: transform 0.18s ease;
    }

    .language-trigger[aria-expanded='true'] .language-caret {
        transform: rotate(225deg) translateY(-1px);
    }

    .language-menu {
        position: absolute;
        right: 0;
        top: calc(100% + 8px);
        width: 100%;
        border-radius: 12px;
        border: 1px solid rgba(148, 163, 184, 0.28);
        background:
            linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 252, 0.97));
        box-shadow: 0 16px 34px rgba(15, 23, 42, 0.16);
        backdrop-filter: blur(10px);
        padding: 6px;
        z-index: 30;
    }

    .language-picker.is-upward .language-menu {
        top: auto;
        bottom: calc(100% + 8px);
    }

    .language-list {
        max-height: min(42vh, 280px);
        overflow: auto;
        padding-right: 1px;
        display: flex;
        flex-direction: column;
        gap: 2px;
    }

    .language-list::-webkit-scrollbar {
        width: 8px;
    }

    .language-list::-webkit-scrollbar-thumb {
        background: rgba(148, 163, 184, 0.46);
        border-radius: 999px;
    }

    :global(.language-option) {
        width: 100%;
        border: 0;
        background: transparent;
        border-radius: 9px;
        min-height: 44px;
        padding: 0 12px;
        text-align: left;
        color: #334155;
        font-size: 0.84rem;
        cursor: pointer;
        transition: background 0.16s ease, color 0.16s ease, transform 0.16s ease;
        display: flex;
        align-items: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        margin-bottom: 2px;
    }

    :global(.language-option:last-child) {
        margin-bottom: 0;
    }

    :global(.language-option:hover) {
        background: rgba(11, 106, 103, 0.1);
        color: #0b6a67;
    }

    :global(.language-option.is-active) {
        background: rgba(11, 106, 103, 0.16);
        color: #0a4f4d;
        font-weight: 700;
    }

    :global(html[dir='rtl']) .language-toolbar {
        align-self: flex-start;
    }

    :global(html[dir='rtl']) .language-trigger {
        text-align: right;
        grid-template-columns: 14px minmax(0, 1fr);
    }

    :global(html[dir='rtl']) .language-caret {
        justify-self: start;
    }

    :global(html[dir='rtl']) .language-menu {
        right: auto;
        left: 0;
    }

    :global(html[dir='rtl'] .language-option) {
        text-align: right;
    }

    .card-glow {
        position: absolute;
        inset: -38% auto auto 54%;
        width: 250px;
        height: 250px;
        border-radius: 999px;
        background: radial-gradient(circle, rgba(11, 106, 103, 0.2), transparent 72%);
        pointer-events: none;
    }

    .card-confetti {
        position: absolute;
        z-index: 0;
        pointer-events: none;
    }

    .card-confetti-a {
        top: 36px;
        right: 38px;
        width: 13px;
        height: 13px;
        border-radius: 4px;
        transform: rotate(17deg);
        background: rgba(245, 158, 11, 0.34);
    }

    .card-confetti-b {
        top: 90px;
        right: 64px;
        width: 24px;
        height: 6px;
        border-radius: 999px;
        transform: rotate(-20deg);
        background: rgba(11, 106, 103, 0.22);
    }

    .card-confetti-c {
        left: 26px;
        bottom: 112px;
        width: 9px;
        height: 9px;
        border-radius: 999px;
        background: rgba(236, 72, 153, 0.2);
    }

    #auth-view,
    #twofa-view,
    #dashboard-view {
        position: relative;
        z-index: 1;
    }

    .login-header {
        margin-bottom: 28px;
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        align-self: flex-start;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.66);
        border: 1px solid rgba(15, 23, 42, 0.1);
        color: var(--primary-strong);
        text-transform: uppercase;
        letter-spacing: 0.12em;
        font-size: 11px;
        font-weight: 700;
    }

    .login-header h2 {
        margin: 14px 0 8px;
        font-size: clamp(2rem, 4vw, 2.75rem);
        line-height: 1;
        letter-spacing: -0.05em;
        color: var(--text);
    }

    .login-header h2::after {
        content: '';
        display: block;
        width: 58px;
        height: 6px;
        margin-top: 14px;
        border-radius: 999px;
        transform: rotate(-2deg);
        transform-origin: left center;
        background: linear-gradient(90deg, rgba(11, 106, 103, 0.84), rgba(245, 158, 11, 0.5));
    }

    .login-header p {
        margin: 0;
        color: var(--text-subtle);
        font-size: 0.97rem;
        line-height: 1.7;
    }

    .form-item {
        margin-bottom: 16px;
    }

    .form-item label {
        display: block;
        margin-bottom: 8px;
        font-size: 0.85rem;
        font-weight: 700;
        color: #334155;
        letter-spacing: 0.01em;
    }

    input {
        width: 100%;
        height: 52px;
        padding: 0 16px;
        border-radius: 18px;
        border: 1px solid rgba(148, 163, 184, 0.28);
        background: rgba(255, 255, 255, 0.88);
        color: var(--text);
        font-size: 0.96rem;
        box-sizing: border-box;
        transition: border-color 0.18s ease, box-shadow 0.18s ease, transform 0.18s ease, background 0.18s ease;
    }

    input::placeholder {
        color: #94a3b8;
    }

    input:focus {
        outline: none;
        border-color: rgba(11, 106, 103, 0.6);
        box-shadow: 0 0 0 4px rgba(11, 106, 103, 0.11);
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.98);
    }

    input[readonly] {
        background: rgba(248, 250, 252, 0.94);
        color: #475569;
        cursor: default;
    }

    .password-complexity {
        margin: -4px 0 16px;
        padding: 4px 2px 2px;
    }

    .password-complexity-spectrum {
        position: relative;
        width: 100%;
        height: 8px;
        overflow: hidden;
        border-radius: 999px;
        background: rgba(203, 213, 225, 0.54);
    }

    .password-complexity-spectrum::before {
        content: '';
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(248, 113, 113, 0.32), rgba(251, 191, 36, 0.22), rgba(74, 222, 128, 0.28));
        opacity: 0.85;
    }

    .password-complexity-fill {
        position: relative;
        display: block;
        height: 100%;
        width: 0;
        border-radius: 999px;
        transition: width 0.22s ease, background 0.22s ease, box-shadow 0.22s ease;
    }

    .password-complexity-fill.is-idle {
        width: 0;
        background: transparent;
        box-shadow: none;
    }

    .password-complexity-fill.is-simple {
        background: linear-gradient(90deg, rgba(248, 113, 113, 0.94), rgba(239, 68, 68, 0.96));
        box-shadow: 0 0 0 1px rgba(239, 68, 68, 0.1), 0 6px 14px rgba(239, 68, 68, 0.18);
    }

    .password-complexity-fill.is-medium {
        background: linear-gradient(90deg, rgba(251, 191, 36, 0.95), rgba(245, 158, 11, 0.96));
        box-shadow: 0 0 0 1px rgba(245, 158, 11, 0.1), 0 6px 14px rgba(245, 158, 11, 0.16);
    }

    .password-complexity-fill.is-complex {
        background: linear-gradient(90deg, rgba(74, 222, 128, 0.92), rgba(22, 163, 74, 0.92));
        box-shadow: 0 0 0 1px rgba(34, 197, 94, 0.08), 0 6px 14px rgba(34, 197, 94, 0.16);
    }

    .input-with-action {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 112px;
        gap: 10px;
        align-items: center;
    }

    .input-with-action.is-single {
        grid-template-columns: minmax(0, 1fr);
    }

    .input-with-action input {
        min-width: 0;
    }

