---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body>
		<slot />
		<footer class="subtle-footer">
			<a href="https://github.com/nhirsama/foolsignup" target="_blank" rel="noopener noreferrer" title="View on GitHub">
				<svg height="16" viewBox="0 0 16 16" width="16" aria-hidden="true">
					<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"></path>
				</svg>
			</a>
		</footer>
	</body>
</html>
<style is:global>
	.subtle-footer {
		position: fixed;
		bottom: 18px;
		left: 0;
		right: 0;
		display: flex;
		justify-content: center;
		pointer-events: none;
		z-index: 999;
	}
	.subtle-footer a {
		pointer-events: auto;
		color: rgba(15, 23, 42, 0.22);
		transition: all 0.3s ease;
		display: flex;
		align-items: center;
		padding: 8px;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.42);
		backdrop-filter: blur(8px);
	}
	.subtle-footer a:hover {
		color: rgba(15, 23, 42, 0.5);
		transform: scale(1.1);
	}
	:root {
		--primary-color: #0f766e;
		--text-color: #0f172a;
		--text-secondary: #64748b;
		--border-color: rgba(148, 163, 184, 0.24);
		--bg-color: #eef5f3;
	}
	html, body {
		margin: 0;
		padding: 0;
	}
	html {
		min-height: 100%;
		background-color: var(--bg-color);
	}
	body {
		min-height: 100dvh;
		font-family: 'Avenir Next', 'SF Pro Display', 'Segoe UI', sans-serif;
		background:
			radial-gradient(circle at top, rgba(255, 255, 255, 0.92), transparent 34%),
			linear-gradient(135deg, #f5f7ef 0%, #e7f3f0 42%, #edf4ff 100%);
		background-color: var(--bg-color);
		background-attachment: fixed;
		background-repeat: no-repeat;
		color: var(--text-color);
		-webkit-font-smoothing: antialiased;
		text-rendering: optimizeLegibility;
	}
	* {
		box-sizing: border-box;
	}

	@media (max-width: 820px) {
		.subtle-footer {
			display: none;
		}
	}
</style>
